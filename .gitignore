# =============================================
# EggVision - .gitignore
# =============================================

# Ambiente virtual Python
venv/
.venv/
env/

# Cache Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Dataset (imagens são pesadas demais para git)
raw_dataset/
dataset/
dataset_augmented/
datasets/egg_crack_seg/images/
datasets/egg_crack_seg/labels/

# Resultados de treinamento (modelos são pesados)
runs/
outputs/
*.pt

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Distribuição
dist/
build/
*.egg-info/
